<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.marlodev.app_android">
    <!-- Permiso para acceder a Internet -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.app_android"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".ui.barista.BaristaHistorialFrag"
            android:exported="false" />
        <activity
            android:name=".ui.barista.BaristaInventarioFragment"
            android:exported="false" />
        <activity
            android:name=".ui.barista.BaristaInicioFragment"
            android:exported="false" />
        <activity
            android:name=".ui.barista.GestionPedidosFragment"
            android:exported="false" />
        <activity
            android:name=".ui.delivery.DeliveryMainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.barista.BaristaMainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.admin.AdminMainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.home.customer.ClientDetailActivity"
            android:exported="false" /> <!-- SplashActivity: launcher -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApp.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.app_android" />

<!--        Nuevo producto-->
        <activity android:name=".ui.admin.NewProductActivity" />

        <!--        Editar producto-->
        <activity android:name=".ui.admin.EditProductActivity" />

<!--        Cick en perfil de usuario admin-->
        <activity android:name=".ui.admin.UserAdminActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"/>


        <activity android:name=".ui.admin.NotificationsActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />


    </application>

</manifest>