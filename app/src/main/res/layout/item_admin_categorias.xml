<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#DDDDDD"
    app:strokeWidth="1dp"
    android:layout_marginEnd="10dp"
    app:cardUseCompatPadding="true"
    >


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- ICONO -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="#EFEFEF"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/iconImage"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_coffe"
                app:tint="#424242" />
        </com.google.android.material.card.MaterialCardView>

        <!-- TITULO + ESTADO -->
        <LinearLayout
            android:id="@+id/titleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_toEndOf="@id/iconContainer"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cafés"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Activa"
                android:textColor="#1B5E20"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/descriptionText"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/titleContainer"
            android:layout_alignStart="@id/titleContainer"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Capuchinos, expreso, mocca y latte macchiato."
            android:textColor="#757575"
            android:textSize="11sp" />

        <!-- BOTONES -->
        <LinearLayout
            android:id="@+id/actionsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/editButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_edit"
                    app:tint="#424242" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/deleteButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_delete"
                    app:tint="#424242" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- PRODUCTOS -->
        <TextView
            android:id="@+id/productsCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/descriptionText"
            android:layout_alignStart="@id/descriptionText"
            android:layout_marginTop="8dp"
            android:text="12 productos"
            android:textColor="#424242"
            android:textSize="11sp" />

        <!-- FECHA -->
        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/productsCount"
            android:layout_alignParentEnd="true"
            android:text="Creada: 2025-09-22"
            android:textColor="#757575"
            android:textSize="11sp" />

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
