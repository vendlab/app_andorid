                            <!-- Texto del porcentaje -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/hoy_porcentajes"
                                android:textSize="8sp" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Tarjeta: Semana -->
                    <LinearLayout
