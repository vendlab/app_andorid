                    android:layout_height="0dp"
                    android:layout_weight="6"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal"
                    android:paddingHorizontal="10dp">

                    <!-- Tarjeta: Productos más vendidos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/b_white_layout"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <!-- Encabezado con título y botón Hoy -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="5dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">
                                <!-- Título -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:text="@string/productos_vendidos"
                                    android:gravity="center_vertical"
                                    android:textSize="11sp"
                                    />

                            </LinearLayout>


                            <!-- Botón Hoy -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="90dp"
                                android:background="@drawable/b_gray_layout"
                                android:orientation="horizontal"
                                android:padding="3dp"

                                >


                                <ImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_marginEnd="5dp"
                                    android:src="@drawable/star_black" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Hoy"
                                    android:textColor="#000000"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />


                            </LinearLayout>
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@android:color/white">

                            <!-- Sección izquierda: ranking, ícono, nombre, categoría, unidades -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:orientation="horizontal"
                                android:layout_marginBottom="15dp"
                                android:gravity="center_vertical">

                                <!-- Ranking -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/dot_gray"
                                    android:padding="6dp"
                                    android:layout_marginEnd="6dp"
                                    android:gravity="center">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="#1"
                                        android:textColor="#000000"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- Ícono -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="30dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/gray_layout"
                                    android:gravity="center"
                                    android:padding="4dp">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/capuccino" />
                                </LinearLayout>

                                <!-- Texto: nombre, categoría, unidades -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Capuccino Grande"
                                        android:textColor="#000000"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Cafés"
                                        android:textColor="#000000"
                                        android:textSize="8sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Vendidos: 68 unidades"
                                        android:textColor="#000000"
                                        android:textSize="9sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Sección derecha: ingresos, crecimiento, precio unitario -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="5dp"
                                android:gravity="end">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="S/ 8.50 c/u"
                                    android:textColor="#000000"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />


                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

