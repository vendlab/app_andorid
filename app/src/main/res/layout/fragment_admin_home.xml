                    android:gravity="center_horizontal"
                    android:paddingHorizontal="10dp">

                    <!-- Tarjeta: Ventas por Categoría -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/b_white_layout"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">

                        <!-- Título -->

                        <!-- Gráfico circular -->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginRight="80dp"
                            android:text="@string/ventas_categoria"
                            android:textSize="10sp" />

                        <ImageView
                            android:layout_width="160dp"
                            android:layout_height="80dp"
                            android:layout_marginRight="60dp"
                            android:layout_marginTop="-0dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="Gráfico de ventas por categoría" />


                        <LinearLayout
                            android:layout_width="100dp"
                            android:layout_height="85dp"
                            android:gravity="center_horizontal"
                            android:layout_marginLeft="90dp"
                            android:layout_marginTop="-90dp"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <!-- Café -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:layout_marginTop="2dp"
                                    android:layout_marginEnd="6dp"
                                    android:layout_marginBottom="2dp"
                                    android:background="@drawable/dot_orange"

                                    />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Café - 45%"
                                    android:textColor="#000000"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <!-- Panes -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/dot_skyblue"
                                    android:backgroundTint="#2196F3" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Panes - 25%"
                                    android:textColor="#000000"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <!-- Frappes -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/dot_green"
                                    />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Frappes - 20%"
                                    android:textColor="#000000"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <!-- Postres -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/dot_brown"
                                    />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Postres - 10%"
                                    android:textColor="#000000"
                                    android:textSize="10sp" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>



                <!-- Productos más vendidos -->

                <LinearLayout
