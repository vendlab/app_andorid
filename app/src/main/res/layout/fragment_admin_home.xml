                                        android:layout_height="12dp"
                                        android:src="@drawable/flecha"
                                        android:layout_marginEnd="4dp"
                                        android:contentDescription="Flecha arriba" />

                                    <!-- Texto del porcentaje -->
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="+15.2%"
                                        android:textSize="8sp" />
                                </LinearLayout>











                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="S/ 578.00"
                                    android:textColor="#000000"
                                    android:textSize="9sp" />

                                <ProgressBar
                                    android:id="@+id/progresoVentas"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:layout_marginTop="8dp"
                                    android:progress="15"
                                    android:max="100"
                                    android:progressDrawable="@drawable/progress_green" />


                                <!-- Línea gris inferior -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginTop="4dp"
                                    android:background="#DDDDDD" />

                            </LinearLayout>

                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical"
                            android:background="@android:color/white">

                            <!-- Sección izquierda: ranking, ícono, nombre, categoría, unidades -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:orientation="horizontal"

                                android:gravity="center_vertical">

                                <!-- Ranking -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/dot_gray"
                                    android:padding="6dp"
                                    android:layout_marginEnd="6dp"
                                    android:gravity="center">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="#2"
                                        android:textSize="10sp"
                                        android:textStyle="bold"
                                        android:textColor="#000000" />
                                </LinearLayout>

                                <!-- Ícono -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="30dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/gray_layout"
                                    android:gravity="center"
                                    android:padding="4dp">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/croissant" />
                                </LinearLayout>

                                <!-- Texto: nombre, categoría, unidades -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Croissant de Mantequilla"
                                        android:textColor="#000000"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Panes"
                                        android:textColor="#000000"
                                        android:textSize="8sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Vendidos: 50 unidades"
                                        android:textColor="#000000"
                                        android:textSize="9sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Sección derecha: ingresos, crecimiento, precio unitario -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="end">


                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="S/ 5.50"
                                    android:textColor="#000000"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <!-- Ícono de flecha -->
                                    <ImageView
                                        android:layout_width="12dp"
                                        android:layout_height="12dp"
                                        android:src="@drawable/flecha"
                                        android:layout_marginEnd="4dp"
                                        android:contentDescription="Flecha arriba" />

                                    <!-- Texto del porcentaje -->
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="+11.4%"
                                        android:textSize="8sp" />
                                </LinearLayout>


                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="S/ 275.00"
                                    android:textColor="#000000"
                                    android:textSize="9sp" />

                                <ProgressBar
                                    android:id="@+id/progresoVentas2"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:layout_marginTop="8dp"
                                    android:progress="15"
                                    android:max="100"
                                    android:progressDrawable="@drawable/progress_black_gray" />


                                <!-- Línea gris inferior -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginTop="4dp"
                                    android:background="#DDDDDD" />

                            </LinearLayout>

                        </LinearLayout>


                    </LinearLayout>
                </LinearLayout>


            </LinearLayout>


        </LinearLayout>
        <!--    </ScrollView>-->



    </LinearLayout>
</ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
