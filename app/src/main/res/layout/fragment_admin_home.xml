                    </LinearLayout>
                </LinearLayout>


                <!-- Ventas por hora y Stock-->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:layout_weight="2"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal"
                    android:paddingHorizontal="10dp">

                    <!-- Tarjeta: Ventas por hora -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="2"
                        android:background="@drawable/b_white_layout"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:layout_marginEnd="15dp">

                        <!-- Título -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ventas_hora"
                            android:textSize="10sp"
                            android:layout_marginTop="10dp"
                            android:layout_marginRight="40dp" />

<!--                        &lt;!&ndash; Imagen del gráfico &ndash;&gt;-->
                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="65dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="Gráfico de ventas por hora" />





                    </LinearLayout>

                    <!-- Tarjeta: Stock -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
