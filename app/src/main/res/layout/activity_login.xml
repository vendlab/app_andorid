<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorGrey100"
    android:padding="0dp">

    <!-- 💚 Encabezado con imagen -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/ic_launcher_background_lr">

        <!-- Imagen derecha -->
        <ImageView
            android:id="@+id/imgLogoRight"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:contentDescription="Logo Derecha"
            android:scaleType="fitCenter"
            android:layout_marginStart="50dp"
            android:src="@drawable/logo_kaphiy_light"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Imagen izquierda -->
        <ImageView
            android:id="@+id/imgLogoLeft"
            android:layout_width="143dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            android:layout_height="188dp"
            android:contentDescription="Logo Izquierda"
            android:scaleType="fitCenter"
            android:src="@drawable/ilustra_login"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 🧾 Formulario -->
    <LinearLayout
        android:background="@drawable/bg_rounded_top"
        android:layout_width="match_parent"
        android:layout_marginTop="-20dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="35dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Iniciar Sesión"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#000000"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="20dp" />

        <!-- ✉️ Correo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de usuario"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:textColor="#000000"
            />
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:hint="Ingresa tu correo"
            android:textColorHint="@color/colorGrey800"
            android:drawableStart="@drawable/icon_email"
            android:drawablePadding="10dp"
            android:paddingStart="16dp"
            android:background="@drawable/bg_input_rounded"
            android:inputType="textEmailAddress"
            android:textColor="#000000"
            android:textSize="16sp"/>

        <!-- 🔑 Contraseña -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:textColor="#000000"
            />
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:hint="Ingresa tu contraseña"
            android:paddingStart="16dp"
            android:drawableStart="@drawable/icon_password"
            android:drawablePadding="10dp"
            android:paddingEnd="16dp"
            android:textColorHint="@color/colorGrey800"
            android:background="@drawable/bg_input_rounded"
            android:inputType="textPassword"
            android:textColor="#000000"
            android:textSize="16sp"/>





        <!-- 🚪 Botón -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#C5D87B"
            android:text="Entrar"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="28dp" />

        <!-- 🌀 ProgressBar simple debajo del botón -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:indeterminateTint="#A5C35D"
            android:visibility="gone"/>

        <!-- 🔗 Enlace de registro -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No tengo cuenta."
                android:textColor="#000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtRegistrarse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Registrarse"
                android:textColor="#A5C35D"
                android:textStyle="bold"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />
    </LinearLayout>
    </LinearLayout>
</LinearLayout>

