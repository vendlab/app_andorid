<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    >

    <TextView
        android:id="@+id/tvTituloEliminar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirmar Eliminación"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvMensajeEliminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Estás seguro de que deseas eliminar el producto?"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvAdvertenciaEliminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Esta acción no se puede deshacer. El producto será eliminado permanentemente"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancelarEliminar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar" />

        <Button
            android:id="@+id/btnConfirmarEliminar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eliminar"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/colorRed"
            android:layout_marginStart="16dp" />
    </LinearLayout>
</LinearLayout>