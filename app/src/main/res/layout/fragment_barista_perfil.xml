<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/baristaMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorGrey100"
    tools:context=".ui.barista.BaristaPerfilFragment">

    <ScrollView
        android:id="@+id/baristaScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Banner -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="350dp">

                <ImageView
                    android:id="@+id/baristaBannerImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/banner_user" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <!-- Foto circular -->
                    <ImageView
                        android:id="@+id/imgBaristaProfile"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/avatar_user_perfil"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_background"
                        android:padding="3dp"
                        android:clipToOutline="true"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvBaristaName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Barista"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorWhite"/>

                    <TextView
                        android:id="@+id/tvBaristaEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textSize="14sp"
                        android:textColor="@color/colorWhiteOpacity50"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>
            </FrameLayout>

            <!-- CARD 1 -->
            <LinearLayout
                android:id="@+id/cardBaristaTop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="-40dp"
                android:padding="16dp"
                android:elevation="4dp"
                android:background="@drawable/bg_white"
                android:clipToOutline="true">

                <!-- Dirección -->
                <LinearLayout
                    android:id="@+id/btnBaristaDireccion"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_gps"
                        app:tint="@color/colorGrey600" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mi Dirección"
                        android:textSize="16sp"
                        android:layout_marginStart="12dp"
                        android:textColor="@color/colorBlack"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_right_arrow"
                        app:tint="@color/colorGrey600"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/colorGrey200"/>

                <!-- Horario -->
                <LinearLayout
                    android:id="@+id/btnBaristaHorario"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_timer"
                        app:tint="@color/colorGrey600" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Horario"
                        android:textSize="16sp"
                        android:layout_marginStart="12dp"
                        android:textColor="@color/colorBlack"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_right_arrow"
                        app:tint="@color/colorGrey600"/>
                </LinearLayout>

            </LinearLayout>

            <!-- CARD 2 -->
            <LinearLayout
                android:id="@+id/cardBaristaSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="16dp"
                android:padding="16dp"
                android:background="@drawable/bg_white"
                android:elevation="4dp"
                android:clipToOutline="true">

                <!-- Notificaciones -->
                <LinearLayout
                    android:id="@+id/btnBaristaNotificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_notify"
                        app:tint="@color/colorGrey600" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Notificaciones"
                        android:textSize="16sp"
                        android:layout_marginStart="12dp"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_right_arrow"
                        app:tint="@color/colorGrey600"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/colorGrey200"/>

                <!-- Dispositivo -->
                <LinearLayout
                    android:id="@+id/btnBaristaDispositivo"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_device"
                        app:tint="@color/colorGrey600" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Dispositivo"
                        android:textSize="16sp"
                        android:layout_marginStart="12dp"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_right_arrow"
                        app:tint="@color/colorGrey600"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/colorGrey200"/>

                <!-- Contraseña -->
                <LinearLayout
                    android:id="@+id/btnBaristaContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_secure"
                        app:tint="@color/colorGrey600" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Contraseña"
                        android:textSize="16sp"
                        android:layout_marginStart="12dp"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_right_arrow"
                        app:tint="@color/colorGrey600"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/colorGrey200"/>

                <!-- Logout -->
                <LinearLayout
                    android:id="@+id/btnBaristaLogout"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_logout"
                        app:tint="@color/colorGrey600" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cerrar sesión"
                        android:textColor="@color/colorBlack"
                        android:layout_marginStart="12dp"
                        android:textSize="16sp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
