<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardResumenVentas"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:background="@color/colorWhite"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Sección izquierda -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Ranking -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/dot_gray"
                android:padding="6dp"
                android:layout_marginEnd="6dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvRanking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#1"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Ícono -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/gray_layout"
                android:gravity="center"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/imgProducto"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/capuccino" />
            </LinearLayout>

            <!-- Nombre, categoría, unidades -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreProducto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Capuccino Grande"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCategoriaProducto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cafés"
                    android:textColor="#000000"
                    android:textSize="8sp" />

                <TextView
                    android:id="@+id/tvUnidadesVendidas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vendidos: 65 unidades"
                    android:textColor="#000000"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sección derecha -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvPrecioUnitario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/.8.50 c/u"
                android:textColor="#000000"
                android:textSize="9sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:id="@+id/imgCrecimiento"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/flecha"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Crecimiento" />

                <TextView
                    android:id="@+id/tvCrecimiento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+15.2%"
                    android:textColor="@color/colorGreen1"
                    android:textSize="8sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTotalVentas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/.578.00"
                android:textColor="#000000"
                android:textSize="9sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Barra de progreso -->
    <ProgressBar
        android:id="@+id/barraVentas"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:progress="65"
        android:max="100"
        android:progressTint="@color/colorGreen1"
        android:backgroundTint="@color/colorGrey300"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="bottom" />


</androidx.cardview.widget.CardView>