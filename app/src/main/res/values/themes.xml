<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema base de la app (diurno) -->
    <style name="Base.Theme.app_android" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores primarios y de la marca -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorGreen2</item>
        <item name="colorOnPrimary">@color/colorGrey400</item>

        <!-- Configuración para las barras del sistema -->
        <!-- El sistema determinará automáticamente el color de los iconos basado en el contraste -->
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/colorBlack</item>
    </style>

    <!-- Tema principal de la app -->
    <style name="Theme.app_android" parent="Base.Theme.app_android" />

    <!-- Tema para SplashActivity -->
    <style name="Theme.MyApp.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/color_green_gradient</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Forzamos iconos claros porque el fondo del splash es oscuro -->
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Otros estilos -->
    <style name="circleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="App.TabLayout.IndicatorDots" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabIndicatorHeight">0dp</item>
        <item name="tabBackground">@drawable/tab_dot</item>
        <item name="tabMinWidth">20dp</item>
        <item name="tabMaxWidth">20dp</item>
        <item name="tabPaddingStart">8dp</item>
        <item name="tabPaddingEnd">8dp</item>
        <item name="tabInlineLabel">true</item>
    </style>

</resources>
