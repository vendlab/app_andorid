<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Dot seleccionado: rectángulo -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <size android:width="30dp" android:height="9dp"/>
            <solid android:color="@color/colorGrey600"/>
            <corners android:radius="9dp"/>
        </shape>
    </item>

    <!-- Dot no seleccionado: círculo -->
    <item>
        <shape android:shape="oval">
            <size android:width="9dp" android:height="9dp"/>
            <solid android:color="@color/colorGrey400"/>
        </shape>
    </item>

</selector>
